# Copy to `.env` on the server and adjust. Docker Compose loads `.env` via `env_file:` in docker-compose.yml.
# Never commit the real `.env` (secrets).

# CRITICAL for clients: the public IPv4 or DNS name of THIS server (same as in the client .conf Endpoint).
# Wrong WG_HOST = handshakes never complete. After changing, restart the container.
WG_HOST=YOUR_PUBLIC_IP_OR_HOSTNAME

# Web UI (HTTP/TCP only). Not used for WireGuard — VPN UDP is WG_PORT (and per-tunnel server.listenPort in JSON).
PORT=51821
# WireGuard default UDP listen port — must fall inside the published UDP range below and match firewall (allow UDP).
WG_PORT=51820
# Optional: publish a UDP port range for multiple tunnels (same on host and in container). If unset, only WG_PORT is published.
WG_UDP_PORT_RANGE=9090-90910
# Inside the container the default route is usually eth0; only change if you know your image uses another iface.
WG_DEVICE=eth0
WG_DEFAULT_ADDRESS=10.8.0.x
WG_DEFAULT_DNS=1.1.1.1
WG_ALLOWED_IPS=0.0.0.0/0, ::/0

# pfSense-style API — required if you use /awg/api (otherwise only /api/compat/amnezia exists)
AMNEZIA_API_ENABLED=true
AMNEZIA_API_AUTH=apikey
AMNEZIA_API_KEY=replace-with-long-random-secret
# Without this line, AMNEZIA_API_BASE_PATH is unset and POST /awg/api will not be registered (405).
AMNEZIA_API_BASE_PATH=/awg/api
